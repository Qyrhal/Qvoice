{
  "name": "qvoice",
  "version": "0.1.0",
  "description": "Local voice-to-text with glass UI",
  "main": "main.js",
  "scripts": {
    "dev": "vite build --config vite.config.js && electron .",
    "build": "vite build --config vite.config.js",
    "start": "vite build --config vite.config.js && electron .",
    "dist": "npm run build && electron-builder --mac --dir && npm run repair-venv",
    "repair-venv": "cp -n \"/Users/avi/.local/share/uv/python/cpython-3.12.0-macos-aarch64-none/lib/libpython3.12.dylib\" \"dist/mac-arm64/Qvoice.app/Contents/Resources/app/.venv/lib/libpython3.12.dylib\" 2>/dev/null; echo \"venv-repaired\"",
    "check-models": ".venv/bin/python check_models.py",
    "setup": "bash setup.sh"
  },
  "dependencies": {
    "@liquid-dom/core": "^0.1.1",
    "@liquid-dom/layout": "^0.2.0",
    "@liquid-dom/react": "^0.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "uiohook-napi": "^1.5.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.16"
  },
  "build": {
    "appId": "com.qvoice.app",
    "productName": "Qvoice",
    "asar": true,
    "asarUnpack": [
      "node_modules/uiohook-napi/**",
      ".venv/**"
    ],
    "icon": "assets/icon.icns",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/icon.icns",
      "target": [{ "target": "dmg", "arch": ["arm64"] }]
    },
    "dmg": {
      "title": "Qvoice",
      "contents": [
        { "x": 130, "y": 220, "type": "file" },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ],
      "window": { "width": 540, "height": 380 }
    },
    "files": [
      "main.js",
      "preload.js",
      "preload-settings.js",
      "transcribe_server.py",
      "check_models.py",
      "download_model.py",
      "renderer/dist/**",
      "assets/**",
      "node_modules/uiohook-napi/**",
      ".venv/**",
      "!.venv/**/__pycache__/**",
      "!.venv/**/*.pyc",
      "!.venv/**/*.pyo",
      "!.venv/**/*.dist-info/**",
      "!.venv/**/tests/**",
      "!.venv/**/test_*.py",
      "!.venv/**/docs/**",
      "!.venv/**/doc/**",
      "!.venv/**/examples/**",
      "!.venv/**/benchmarks/**",
      "!.venv/**/*.pyi",
      "!.venv/**/*.md",
      "!.venv/**/*.rst",
      "!.venv/**/*.h",
      "!.venv/**/*.c",
      "!.venv/**/Makefile"
    ]
  }
}
